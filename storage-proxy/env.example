# Storage Proxy Configuration
# Copy this file to .env and update values

# Required: JWT secret for token signing/validation
JWT_SECRET=your-very-long-random-secret-key-here-minimum-32-bytes

# Required: PostgreSQL URL for JuiceFS metadata
DEFAULT_META_URL=postgres://juicefs:password@localhost:5432/juicefs?sslmode=disable

# AWS credentials (if not using IRSA)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# S3 configuration
DEFAULT_S3_REGION=us-east-1
DEFAULT_S3_ENDPOINT=
DEFAULT_CACHE_SIZE=10G
DEFAULT_CACHE_DIR=/var/lib/storage-proxy/cache

# Server configuration
GRPC_ADDR=0.0.0.0
GRPC_PORT=8080
HTTP_ADDR=0.0.0.0
HTTP_PORT=8081
METRICS_PORT=9090

# Logging
LOG_LEVEL=info
AUDIT_LOG=true
AUDIT_FILE=/var/log/storage-proxy/audit.log

# Performance tuning
MAX_OPS_PER_SECOND=10000
MAX_BYTES_PER_SECOND=1073741824
